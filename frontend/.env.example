# API 서버 주소 (기본값: http://localhost:8080)
VITE_API_BASE_URL=http://localhost:8080

# WebSocket 서버 주소 (기본값: ws://localhost:8080)
VITE_WS_BASE_URL=ws://localhost:8080

# NCP Maps Dynamic Map Client ID
# NCP 콘솔 → Application → Web 서비스 URL: http://localhost:3000 등록 후 발급된 Client ID 입력
VITE_NCP_MAP_CLIENT_ID=your_ncp_client_id_here
