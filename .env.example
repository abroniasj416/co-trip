# =============================================
# co-trip 환경변수 템플릿
# prod 배포 시 이 파일을 복사하여 .env.prod로 사용
# cp .env.example .env.prod && vi .env.prod
# =============================================

# ── GHCR ──
GHCR_OWNER=your-github-username

# ── Database (NCP Cloud DB for PostgreSQL) ──
DB_URL=jdbc:postgresql://your-ncp-db-host:5432/cotrip
DB_USERNAME=cotrip
DB_PASSWORD=your-secure-password

# ── Redis (NCP Cloud DB for Redis) ──
REDIS_HOST=your-ncp-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──
JWT_SECRET=your-production-jwt-secret-key-minimum-32-characters

# ── CORS ──
CORS_ALLOWED_ORIGINS=https://your-domain.com

# ── NCP API ──
NCP_CLIENT_ID=your-ncp-client-id
NCP_CLIENT_SECRET=your-ncp-client-secret

# ── Naver Search API ──
NAVER_SEARCH_CLIENT_ID=your-naver-search-client-id
NAVER_SEARCH_CLIENT_SECRET=your-naver-search-client-secret

# ── NCP Map (frontend 빌드 시 사용) ──
NCP_MAP_CLIENT_ID=your-ncp-map-client-id
